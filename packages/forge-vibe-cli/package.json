{
  "name": "forge-vibe",
  "version": "0.1.0",
  "description": "BMAD-style agent context installer: npx forge-vibe install (AGENTS.md + Claude, Cursor, Gemini, …)",
  "keywords": [
    "agents.md",
    "claude",
    "cursor",
    "cline",
    "gemini",
    "copilot",
    "codex",
    "bmad",
    "installer",
    "ai-agents"
  ],
  "type": "module",
  "main": "./dist/cli.js",
  "bin": {
    "forge-vibe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "packs",
    "schemas"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "repack-forge-vibe": "npm run build && npm run test && node ../../scripts/repack-forge-vibe.mjs"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ajv": "^8.17.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
